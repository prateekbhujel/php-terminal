         version="2.0"
         xmlns="http://pear.php.net/dtd/package-2.0"
         xmlns:tasks="http://pear.php.net/dtd/tasks-1.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pear.php.net/dtd/tasks-1.0 http://pear.php.net/dtd/tasks-1.0.xsd http://pear.php.net/dtd/package-2.0 http://pear.php.net/dtd/package-2.0.xsd">
    <name>terminal</name>
    <channel>pecl.php.net</channel>
    <summary>Cross-platform terminal helpers for PHP CLI.</summary>
    <description>
        The terminal extension exposes a small cross-platform terminal capability layer for PHP CLI programs.
        It currently provides backend detection, TTY checks, ANSI capability checks and enablement, terminal size lookup, direct writes to stdout/stderr, raw-mode save/restore helpers, key input, and hidden secret input.
    </description>
    <lead>
        <name>Pratik Bhujel</name>
        <user>prateekbhujel</user>
        <email>prateekbhujelpb@gmail.com</email>
        <active>yes</active>
    </lead>
    <date>2026-06-06</date>
    <version>
        <release>0.4.1</release>
        <api>0.4.1</api>
    </version>
    <stability>
        <release>beta</release>
        <api>beta</api>
    </stability>
    <license uri="https://www.php.net/license/3_01.txt">PHP License</license>
    <notes>
        - Added Windows resize-event support: ReadConsoleInputW WINDOW_BUFFER_SIZE_EVENT now returns Terminal\Key::Resize.
        - Documented the default 25ms POSIX sequence timeout used by Terminal\Terminal::readKey().
        - Documented current key-input scope, including UTF-8 code point behavior, control-byte behavior, and function-key/modifier limitations.
    </notes>
