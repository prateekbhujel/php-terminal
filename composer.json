{
    "name": "prateekbhujel/php-terminal",
    "description": "Cross-platform terminal helpers for PHP CLI",
    "type": "php-ext",
    "license": "PHP-3.01",
    "keywords": [
        "cli",
        "extension",
        "terminal"
    ],
    "authors": [
        {
            "name": "Pratik Bhujel",
            "email": "prateekbhujelpb@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/prateekbhujel/php-terminal/issues",
        "source": "https://github.com/prateekbhujel/php-terminal"
    },
    "require": {
        "php": ">=8.1"
    },
    "php-ext": {
        "extension-name": "terminal",
        "download-url-method": [
            "pre-packaged-binary",
            "composer-default"
        ],
        "support-zts": true,
        "support-nts": true
    }
}
