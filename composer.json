{
    "name": "prateekbhujel/php-terminal",
    "description": "Native terminal primitives for PHP CLI on Unix and Windows",
    "type": "php-ext",
    "license": "PHP-3.01",
    "keywords": [
        "ansi",
        "cli",
        "console",
        "extension",
        "keyboard",
        "php-extension",
        "pie",
        "raw-mode",
        "terminal",
        "tty",
        "unix",
        "windows"
    ],
    "homepage": "https://github.com/prateekbhujel/php-terminal",
    "authors": [
        {
            "name": "Pratik Bhujel",
            "email": "prateekbhujelpb@gmail.com",
            "role": "Maintainer"
        }
    ],
    "support": {
        "docs": "https://github.com/prateekbhujel/php-terminal#readme",
        "issues": "https://github.com/prateekbhujel/php-terminal/issues",
        "source": "https://github.com/prateekbhujel/php-terminal"
    },
    "require": {
        "php": ">=8.1"
    },
    "php-ext": {
        "extension-name": "terminal",
        "download-url-method": [
            "pre-packaged-binary",
            "composer-default"
        ],
        "support-zts": true,
        "support-nts": true
    }
}
